    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "minimalhtml",
    "aspnetcore",
    "manifest"
  ],
  "license": "MIT",
  "author": "Felix Cornelissen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flixcor/minimalhtml.git",
    "directory": "npm/vite"
  },
  "homepage": "https://github.com/flixcor/minimalhtml/tree/main/npm/vite",
  "bugs": "https://github.com/flixcor/minimalhtml/issues",
  "peerDependencies": {
    "vite": ">=8.0.0-beta.0"
  },
  "dependencies": {
    "tinyglobby": "^0.2.16",
    "vite-plugin-manifest-sri": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.8"
  }
