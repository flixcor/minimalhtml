{
  "name": "@minimalhtml/vite",
  "version": "0.0.1-alpha.8",
  "description": "Vite plugin for MinimalHtml: marker-based asset discovery, manifest + importmap emission",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
